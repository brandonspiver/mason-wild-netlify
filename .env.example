# Site URL — used for canonical metadata and OG tags
# Set this to your production domain in Netlify's environment variables panel
NEXT_PUBLIC_SITE_URL=https://masonwild.com

# Email delivery (all form entries route to hello@masonandwild.com)
RESEND_API_KEY=
RESEND_FROM=Mason & Wild <hello@masonandwild.com>
# Optional override for destination inbox (defaults to hello@masonandwild.com)
# FORM_SUBMISSIONS_TO=hello@masonandwild.com

# Add future integrations below:
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
